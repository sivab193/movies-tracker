{
    "builds": [
        {
            "src": "backend/app.py",
            "use": "@vercel/python"
        },
        {
            "src": "ui/package.json",
            "use": "@vercel/next"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "backend/app.py"
        },
        {
            "src": "/users/(.*)",
            "dest": "/ui/users/[id]?id=$1"
        },
        {
            "src": "/movie/(.*)",
            "dest": "/ui/movie/[id]?id=$1"
        },
        {
            "src": "/(.*)",
            "dest": "/ui/$1"
        }
    ]
}